extends ../layout 
include ../mixins/error

block content-header
block content
  h2.page-title Update Video 
  hr.title--divider 

  if errorMsg 
    +error(errorMsg)

  form(method="post")
    label(for="title") Title
    input(id="title", placeholder="Video Title", type="text", required, name="title", maxlength=80, value=video.title)
    label(for="description") Description
    textarea(id="description", placeholder="Video Description", required, name="description", minlength=20)=video.description
    label(for="hashtags") Hashtags (Separate multiple values with a comma)
    input(id="hashtags", placeholder="Hashtags", type="text", required, name="hashtags", value=video.hashtags.map(tag => tag.slice(1)).join(", "))
    button(type="submit") Edit Video!
    button(type="button" class="cancelEditBtn") Cancel